# The Oracle - Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# Application Mode
# Options: development, production
MATRIX_MODE=development

# Database Connection
# Development: Use local database
# Production: Use actual production database URL
DATABASE_URL=postgresql://localhost:5432/matrix_dev

# API Key for External Services
# Development: Use test key
# Production: Use actual API key from secure vault
API_KEY=dev_test_key_12345678

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Development: DEBUG for verbose logging
# Production: WARNING or ERROR for minimal logging
LOG_LEVEL=DEBUG

# Zion Network Endpoint
# The resistance's communication endpoint
# Development: Local testing endpoint
# Production: Actual network address
ZION_ENDPOINT=http://localhost:8080/zion